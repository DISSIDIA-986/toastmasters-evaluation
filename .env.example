# Vercel Postgres Connection
# These are automatically set when you connect Vercel Postgres in the Vercel dashboard
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin auth (P1). Set both in Vercel project env + .env.local for local dev.
# ADMIN_PASSWORD: shared Executive-Committee sign-in password.
# COOKIE_SECRET:  HMAC key for signing session + submit tokens (>=16 chars,
#                 use a long random string). Rotating it logs everyone out.
ADMIN_PASSWORD=
COOKIE_SECRET=

# Retention cron (P5). Vercel sends "Authorization: Bearer $CRON_SECRET" to the
# scheduled /api/cron/purge route; the route rejects anything else.
CRON_SECRET=

# Email (P4). RESEND_API_KEY from resend.com. EMAIL_FROM defaults to Resend's
# onboarding domain (only delivers to the account owner) until you verify a club
# sending domain (SPF/DKIM) and set e.g. "Spoken Word Club <noreply@yourdomain>".
RESEND_API_KEY=
EMAIL_FROM=
# Replies go here (the club's official Gmail). Members who reply reach the Exec
# inbox; we still send FROM the verified domain above.
REPLY_TO=
